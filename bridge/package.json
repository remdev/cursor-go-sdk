{
  "name": "@cursor-go-sdk/cursor-sdk-bridge",
  "version": "0.0.2",
  "description": "Unofficial Connect RPC bridge over @cursor/sdk for cursor-go-sdk. Prerequisite for the Go SDK.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remdev/cursor-go-sdk.git",
    "directory": "bridge"
  },
  "homepage": "https://github.com/remdev/cursor-go-sdk/tree/main/bridge",
  "bugs": {
    "url": "https://github.com/remdev/cursor-go-sdk/issues"
  },
  "type": "module",
  "scripts": {
    "generate": "buf generate",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run generate && npm run build"
  },
  "bin": {
    "cursor-sdk-bridge": "dist/bin/cursor-sdk-bridge.js"
  },
  "files": [
    "dist",
    "gen",
    "proto"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@bufbuild/protobuf": "1.10.1",
    "@connectrpc/connect": "1.7.0",
    "@connectrpc/connect-node": "1.7.0",
    "@cursor/sdk": "1.0.18"
  },
  "optionalDependencies": {
    "@cursor/sdk-darwin-arm64": "1.0.18",
    "@cursor/sdk-darwin-x64": "1.0.18",
    "@cursor/sdk-linux-arm64": "1.0.18",
    "@cursor/sdk-linux-x64": "1.0.18",
    "@cursor/sdk-win32-x64": "1.0.18"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.70.0",
    "@bufbuild/protoc-gen-es": "1.10.1",
    "@connectrpc/protoc-gen-connect-es": "1.7.0",
    "@types/node": "^22.19.21",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "undici": "^6.26.0",
    "tar": "^7.5.16"
  }
}
